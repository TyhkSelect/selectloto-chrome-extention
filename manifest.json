{
  "manifest_version": 3,
  "name": "selectLOTO 購入入力補助",
  "version": "2.0.6",
  "description": "selectloto.jp の組み合わせ（LOTO6・LOTO7・ミニロト）を宝くじ公式サイトへ自動入力します",
  "permissions": ["storage", "activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://selectloto.jp/*",
    "https://staging.selectloto.jp/*",
    "https://*.mizuhobank.co.jp/*",
    "https://*.takarakuji-official.jp/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "selectLOTO 購入入力補助",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://selectloto.jp/*",
        "https://staging.selectloto.jp/*"
      ],
      "js": ["content_selectloto.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://*.mizuhobank.co.jp/*",
        "https://*.takarakuji-official.jp/*"
      ],
      "js": ["content_loto_official.js"],
      "run_at": "document_idle"
    }
  ]
}
